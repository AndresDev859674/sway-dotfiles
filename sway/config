### Modos de i3
bindsym $mod+Shift+c reload
bindsym $mod+x reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway?' -b 'Yes, exit sway' 'swaymsg exit'

mode "resize" {
    bindsym j resize shrink width 10 px
    bindsym k resize grow height 10 px
    bindsym l resize shrink height 10 px
    bindsym semicolon resize grow width 10 px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bindsym Control+Mod4+Delete exec wlogout

exec ~/.config/i3/scripts/clean_procs.sh

exec_always ~/.config/i3/scripts/sway-check-zombie.sh
exec_always autotiling -w 1 3 5 7 9

exec swaync

bindsym $mod+n exec swaync-client -t -sw

### IDLE y LOCK
exec swayidle -w \
     timeout 300 'swaylock -f -c 000000' \
     timeout 600 'swaymsg "output * power off"' \
     resume 'swaymsg "output * power on"' \
     before-sleep 'swaylock -f -c 000000'

bindsym $mod+mod1+l exec "swaylock -f -c 000000"

exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store

bindsym $mod+c exec cliphist list | rofi -dmenu | cliphist decode | wl-copy
bindsym $mod+Delete+c exec cliphist wipe
bindsym $mod+mod1+b exec dmenufm

bindsym $mod+mod1+e exec bemoji
bindsym Control+mod1+t exec ~/.config/i3/scripts/calendar.sh

exec ~/.config/i3/scripts/holiday_nag.sh
# Modo nocturno
# Agendar el cambio de temperatura a las 7 PM al iniciar Sway
exec_always gammastep -l 40.4:-3.7 -t 6500:3500 19:00 07:00
# Tecla para Desativar
bindsym Control+mod1+g exec pkill -x gammastep && notify-send "Night Mode Killed" "Now you can use the desktop with the normal"

bindsym Control+Mod4+s exec ~/.config/i3/scripts/selector-chars.sh

gaps inner 10

### Barra de Estado [cite: 26, 27]
bar {
    status_command i3status-rs ~/.config/i3status-rust/config.toml
    position top
    colors {
        background #123456AA
        statusline #666666
        separator #222222

        focused_workspace #abcdef #abcdef #ffffff
        active_workspace   #fbf1c7 #123456 #282828
        inactive_workspace #123456 #123456 #abcdef
        urgent_workspace #ff5555 #ff5555 #ffffff
    }

    tray {
        bindsym BTN_RIGHT ContextMenu
    }
}

# --- Esquinas Redondeadas ---
corner_radius 10

# --- Sombras ---
shadows enable
shadow_blur_radius 10
shadow_color #123456AA

# --- Difuminado (Blur) ---
 blur enable
 blur_passes 3
 blur_radius 2
 blur_xray disable

# --- Opacidad (Dim) ---
# Esto reemplaza tu active/inactive opacity de picom
default_dim_inactive 0.1

# --- Efectos en la barra (Waybar/swaybar) ---
layer_effects "waybar" blur enable; corner_radius 10

layer_effects "rofi" {
    default_dim_inactive 0.1
    corner_radius 5
    blur enable
}

for_window [app_id="UNDERTALE"] floating enable
for_window [app_id="Main"] floating enable, blur disable
for_window [app_id="steam"] border none
for_window [app_id="wlogout"] floating enable, border none, sticky enable
