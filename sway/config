bindsym Shift+Print exec --no-startup-id ~/.config/i3/scripts/screenshot.sh select

# --- Configuración de Volumen Universal con swayosd ---

# SUBIR VOLUMEN
bindsym $mod+plus exec swayosd-client --output-volume +5 --max-volume 255
bindsym $mod+KP_Add exec swayosd-client --output-volume +5 --max-volume 255

# BAJAR VOLUMEN
bindsym $mod+minus exec swayosd-client --output-volume -5 --max-volume 255
bindsym $mod+KP_Subtract exec swayosd-client --output-volume -5 --max-volume 255

# SILENCIAR
bindsym $mod+m exec swayosd-client --output-volume mute-toggle

# Brightness controls
bindsym --locked XF86MonBrightnessUp exec brightnessctl s +5%
bindsym --locked XF86MonBrightnessDown exec brightnessctl s 5%-

### Gestión de Ventanas y Movimiento [cite: 15, 17]
