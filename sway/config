### Solucionar mi problema de abrir, descargar archivos xd
exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec hash dbus-update-activation-environment 2>/dev/null && \
dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP

exec swayosd-server --style ~/.config/swayosd/style.css
exec XDG_MENU_PREFIX=plasma- kbuildsycoca6

# output VGA-1 mode 1440x900@74.984Hz

include ~/.config/sway/outputs
include ~/.config/sway/workspaces.conf

# prefiero nwg-displays que poner un output

input * xkb_numlock enabled
# Elimina esto si prefieres

exec rm -f /tmp/sovpipe && mkfifo /tmp/sovpipe && tail -f /tmp/sovpipe | sov -t 500

### Variables de entorno y Modificador
set $mod Mod4
set $refresh_i3status killall -SIGUSR1 i3status

exec swaycons

### Estética de Ventanas
default_border pixel 2
title_align center

# Formato: class             border    backgr.   text    indicator child_border
client.focused           #b9dcff99 #12345699 #abcdef #8be9fd   #8be9fd99
client.focused_inactive  #44475a99 #282a3699 #6272a4 #44475a   #44475a99
client.unfocused         #282a3699 #282a3699 #6272a4 #282a36   #282a3699

### Fuentes [cite: 6]
font pango:JetBrainsMono Nerd Font 12

### Autostart (Adaptado para Wayland)

exec --no-startup-id dex --autostart --environment sway
exec --no-startup-id nm-applet
exec_always --no-startup-id swaync
# exec_always --no-startup-id dunst
# adios fuiste un buen amigo
exec --no-startup-id /usr/libexec/polkit-gnome-authentication-agent-1

exec awww-daemon
exec_always sh -c 'sleep 0.5 && awww img "$(cat $HOME/.current_wallpaper || echo $HOME/i3-wallpapers/i3-6.png)" --transition-type outer --transition-duration 0.3'

### Atajos de Teclado Personalizados
bindsym $mod+t exec ~/.config/i3/scripts/toggle_borders.sh
bindsym Mod4+Mod1+t exec ~/.config/i3/scripts/table.sh
bindsym Mod4+Control+v exec ~/.config/i3/scripts/media_info
bindsym $mod+mod1+Return exec alacritty
bindsym Mod4+Mod1+w exec ~/.config/i3/wallpaper.sh
bindsym Mod4+Control+T exec ~/.config/i3/scripts/tools_menu
bindsym Mod4+Control+O exec ~/.config/i3/scripts/options_menu
