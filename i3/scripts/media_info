#!/bin/bash

TMP_DIR="/tmp/dunst_covers"
mkdir -p "$TMP_DIR"

# 1. Obtener todos los reproductores
ALL_PLAYERS=$(playerctl -l 2>/dev/null)

# 2. Lógica de filtrado inteligente:
# Si existe Plasma Integration, borramos los nombres genéricos de navegadores
if echo "$ALL_PLAYERS" | grep -q "plasma-browser-integration"; then
    # Filtramos navegadores pero MANTENEMOS plasma y otros (VLC, etc)
    PLAYERS=$(echo "$ALL_PLAYERS" | grep -vE "firefox|chrome|chromium" | head -n 5)
else
    # Si no hay Plasma, mostramos lo que haya hasta 5
    PLAYERS=$(echo "$ALL_PLAYERS" | head -n 5)
fi

# 3. Procesar la lista filtrada
for PLAYER in $PLAYERS; do
    STATUS=$(playerctl -p "$PLAYER" status 2>/dev/null)
    [ -z "$STATUS" ] && continue

    TITLE=$(playerctl -p "$PLAYER" metadata title 2>/dev/null)
    ARTIST=$(playerctl -p "$PLAYER" metadata artist 2>/dev/null)
    ART_URL=$(playerctl -p "$PLAYER" metadata mpris:artUrl 2>/dev/null)

    # Nombre estético para la App
    if [[ "$PLAYER" == *"plasma-browser-integration"* ]]; then
        APP_NAME="Web / Browser"
    else
        APP_NAME=$(echo "$PLAYER" | cut -d. -f1 | sed 's/./\U&/')
    fi

    # ID Único basado en el nombre (ID entre 1 y 65535)
    ID_NUM=$(echo "$PLAYER" | sum | cut -d ' ' -f 1)

    # Gestionar Carátula
    CLEAN_PLAYER=$(echo "$PLAYER" | tr -d '.')
    ICON_PATH="$TMP_DIR/cover_${CLEAN_PLAYER}.png"

    if [ -n "$ART_URL" ]; then
        CLEAN_URL=$(echo "$ART_URL" | sed 's/file:\/\///g' | sed 's/%20/ /g')
        if [[ "$ART_URL" == http* ]]; then
            curl -sL "$ART_URL" -o "$ICON_PATH"
        else
            cp "$CLEAN_URL" "$ICON_PATH" 2>/dev/null
        fi
        FINAL_ICON="$ICON_PATH"
    else
        FINAL_ICON="audio-x-generic"
    fi

    # Notificar
    dunstify -u low -r "$ID_NUM" -i "$FINAL_ICON" "$APP_NAME: $STATUS" "<b>$TITLE</b>\n<i>$ARTIST</i>"
done
