{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "margin-left": 12,
    "margin-right": 12,
    "margin-bottom": 10,
    "margin-top": 7,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/separator",
        "sway/window"
    ],
    "modules-center": [
        "mpris",
        "custom/cava"
    ],
    "modules-right": [
        "disk",
        "cpu",
        "memory",
        "pulseaudio",
        "clock",
        "tray",
        "custom/power",
        "custom/config",
        "custom/panel"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name} {icon}",
        "format-icons": {
            "1": "",
            "2": "",
            "3": "",
            "4": "",
            "5": "",
            "urgent": "",
            "focused": "",
            "default": ""
        }
    },

    "sway/mode": {
        "format": " {}"
    },

    "sway/window": {
        "format": "{}",
        "max-length": 40
    },

    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "",
            "spotify": ""
        },
        "status-icons": {
            "paused": ""
        },
        "dynamic-len": 35,
        "dynamic-order": ["title", "artist"]
    },

    "disk": {
        "interval": 30,
        "format": " {free}",
        "path": "/"
    },

    "cpu": {
        "interval": 2,
        "format": " {usage}%",
        "states": {
            "warning": 75,   // Tu petición: 75%
            "critical": 90   // Muy alto
        },
        "tooltip": false
    },

    "memory": {
        "interval": 2,
        "format": " {}%",
        "states": {
            "warning": 70,   // Alrededor de 7GB usados
            "critical": 85   // Rojo: aprox 8.5GB de tus 10GB
        }
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-muted": " Mute",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": " {:%I:%M %p}",
        "format-alt": " {:%a %d/%m/%Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10,
        "show-passive-items": true
    },

    "custom/separator": {
        "format": "|",
        "tooltip": false
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "wlogout",
        "on-click-right": "~/.config/i3blocks/scripts/shutdown_menu"
    },

    "custom/config": {
        "format": "",
        "tooltip": false,
        "on-click": "~/.config/i3/scripts/options_menu"
    },

    "custom/panel": {
        "format": "",
        "tooltip": false,
        "on-click": "swaync-client -t -sw"
    }
}
